{
  "redirects": [
    {
      "source": "/map",
      "destination": "https://map.lakemichiganshore.wine/",
      "statusCode": 301
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Prerender-Token",
          "value": "true"
        }
      ]
    }
  ]
}
